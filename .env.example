# ═══════════════════════════════════════════════════════════════
# 🤖 GANDIVE BOT — Environment Configuration
# ═══════════════════════════════════════════════════════════════
#
# Quick start:
#   1. cp .env.example .env
#   2. Fill in your Telegram credentials
#   3. pip install -r requirements.txt
#   4. python bot.py
#
# Get your credentials:
#   Bot token:   Message @BotFather on Telegram -> /newbot
#   Admin ID:    Message @userinfobot to get your Telegram user ID
#
# ⚠ NEVER commit .env to git. It's in .gitignore.
# ═══════════════════════════════════════════════════════════════

# ─── Required: Telegram ───────────────────────────────────────────

# Your Telegram bot token from @BotFather (e.g. "123456:ABC-DEF1234ghIkl")
GANDIVE_BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (numeric). Enables admin commands:
#   /addpremium, /removepremium, /listpremium, /broadcast, etc.
ADMIN_USER_ID=your_admin_user_id_here

# ─── Optional: Bot Info ───────────────────────────────────────────

BOT_NAME=GandiveBot
BOT_USERNAME=GandiveBot

# ─── Optional: Signal Settings ────────────────────────────────────

# How often to scan for signals (seconds). Default: 300 (5 min)
SCAN_INTERVAL=300

# Minimum volume spike multiplier. Default: 3.0 (3x normal volume)
VOLUME_SPIKE_MULTIPLIER=3.0

# Minimum price breakout percentage. Default: 0.05 (5%)
PRICE_BREAKOUT_PCT=0.05

# Minimum confidence score for signals. Default: 60 (0-100)
MIN_SIGNAL_CONFIDENCE=60

# ─── Optional: Whale Alert API (for whale transaction alerts) ─────
# Get a free API key at https://whale-alert.io/
WHALE_ALERT_API_KEY=

# ─── Optional: Payment ────────────────────────────────────────────
# Your Ko-fi page URL for subscription payments
KO_FI_URL=https://ko-fi.com/adbhutrd
# Your Ko-fi name displayed in messages
KO_FI_NAME=Adbhut_RD

# ─── Ko-fi Webhook Verification ──────────────────────────────────
# REQUIRED to secure payments. Create a token in Ko-fi Settings → Webhooks,
# then paste it here and in Ko-fi's verification token field.
# Without this, ANYONE can activate premium by calling your webhook URL.
KO_FI_VERIFICATION_TOKEN=

